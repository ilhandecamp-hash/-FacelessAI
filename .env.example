# Clé API Groq (gratuite) - https://console.groq.com/keys
# Utilisée pour générer le script/texte de la vidéo à partir d'un sujet.
GROQ_API_KEY=your_groq_api_key_here

# Clé API Pexels (gratuite) - https://www.pexels.com/api/
# Utilisée pour récupérer une vidéo de fond libre de droits.
PEXELS_API_KEY=your_pexels_api_key_here

# Voix edge-tts par défaut (voir "edge-tts --list-voices" pour la liste complète)
TTS_VOICE=fr-FR-HenriNeural

# Identifiants OAuth Google (gratuits) - https://console.cloud.google.com
# Nécessaires pour activer "Se connecter avec Google". Sans eux, l'app
# fonctionne quand même mais la connexion est désactivée.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Clé secrète utilisée pour signer les cookies de session. Génère une valeur
# aléatoire forte (ex: python -c "import secrets; print(secrets.token_hex(32))")
# et garde-la identique entre redémarrages pour ne pas invalider les sessions.
SESSION_SECRET_KEY=change_me_to_a_random_secret_string
